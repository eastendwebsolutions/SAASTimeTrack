# Copy to .env.local for local dev. Set the same keys in Vercel → Project → Settings → Environment Variables (Production).

# Postgres (Vercel Postgres / Neon connection string)
DATABASE_URL=

# Clerk (use production keys on Vercel for your live site)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Public URL of the app (no trailing slash). Local: http://localhost:3000 — Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Asana OAuth — redirect must exactly match Asana app + this value (e.g. https://your-domain.vercel.app/api/asana/callback)
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
ASANA_REDIRECT_URI=http://localhost:3000/api/asana/callback

# Jira OAuth (rollout gated; safe to set ahead of enablement)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3000/api/jira/callback
# Set to 1 only after DB migration is applied and verified in production.
JIRA_FEATURE_ENABLED=0

# Monday.com OAuth (rollout gated; safe to set ahead of enablement)
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
MONDAY_REDIRECT_URI=http://localhost:3000/api/monday/callback
# Set to 1 only after DB migration is applied and verified in production.
MONDAY_FEATURE_ENABLED=0

# 32+ random bytes (base64 or hex string). Do not rotate in production without re-encrypting stored tokens.
ENCRYPTION_KEY=

# Vercel Cron: set in Vercel; Vercel sends Authorization: Bearer <CRON_SECRET> when invoking /api/cron/asana-sync
# On Hobby, crons run at most once per day (see vercel.json schedule).
CRON_SECRET=
